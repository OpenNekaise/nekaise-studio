# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
.ipynb_checkpoints/

# Training artifacts — never commit weights or checkpoints
outputs/
experiments/**/outputs/
# dashboard run telemetry (events.jsonl, meta.json) — ephemeral, rebuilt per run
experiments/**/runs/
checkpoints/
unsloth_compiled_cache/
*.gguf
*.safetensors
*.bin
*.pt
wandb/

# Dataset / HF cache
.cache/
packs/**/data/
# Built dataset artifacts (teacher CoT / rejection-sampled / preference pairs) — rebuilt from SPEC
experiments/**/data/
# Per-experiment training journal — your run-by-run results are PRIVATE (an intermediate log).
# The platform ships the loop/skills, not anyone's specific training history.
experiments/**/LOG.md

# Real building data — NEVER commit (proprietary PDFs, control cards, BIM, PII)
nekaise_data/
# Frozen open-ended exam — derived from the (proprietary) holdout building; grade-against-only
packs/**/eval_open.jsonl

# Workspace — the agent's local scratch (throwaway code, experiments, notes). Never pushed.
workspace/
# Emergent skills — written by the agent (crystallize-skill), per-user, different for everyone.
# A local skill enters the shared kernel (skills/) only by eval-gated, human-reviewed PR.
skills/local/

# Secrets
.env
*.key

# OS / editor
.DS_Store
.idea/
.vscode/
